NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_URL=

# Gmail SMTP fallback pool.
# Comma-separated `email:app_password` pairs. The wrapper tries each in order
# and skips any one that hits its daily quota until next UTC midnight.
# App passwords: https://myaccount.google.com/apppasswords (needs 2FA enabled).
#   Example:
#   GMAIL_ACCOUNTS=concession1@gmail.com:abcdwxyz1234efgh,concession2@gmail.com:hgfe4321zyxwdcba
GMAIL_ACCOUNTS=
GMAIL_FROM_NAME=Concession Office

# v2 only
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
